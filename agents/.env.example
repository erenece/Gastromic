# Ajan katmanı ortam değişkenleri — .env olarak kopyalayın (agents/.env)

# Orkestrasyon motoru: lite (varsayılan) | crew (tam CrewAI)
GASTRO_ENGINE=lite

# AI beyni sağlayıcısı: gemini (varsayılan) | openai | mock
GASTRO_LLM_PROVIDER=gemini
GASTRO_LLM_MODEL=gemini-2.0-flash-001

# Agent Debate tur sayısı (Sprint 2: 3)
GASTRO_DEBATE_ROUNDS=3

# --- AI beyni anahtarı ---
# Gemini için: https://aistudio.google.com/apikey adresinden alın.
# TANIMLI DEĞİLSE kod otomatik mock'a düşer (offline çalışır, sadece AI metni olmaz).
GEMINI_API_KEY=
# GOOGLE_API_KEY= (alternatif isim de okunur)
