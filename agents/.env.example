# Ajan katmanı ortam değişkenleri — .env olarak kopyalayın (agents/.env)

# Çalışma modu: mock (offline, varsayılan) | crew (gerçek CrewAI + sağlayıcı)
GASTRO_LLM_MODE=mock

# crew modunda sağlayıcı: mock | gemini | openai
GASTRO_LLM_PROVIDER=mock
GASTRO_LLM_MODEL=

# Agent Debate tur sayısı (Sprint 1: 0, Sprint 2: 3)
GASTRO_DEBATE_ROUNDS=0

# Sağlayıcı anahtarları (Sprint 2 — mock modda GEREKMEZ)
# GEMINI_API_KEY=
# OPENAI_API_KEY=
